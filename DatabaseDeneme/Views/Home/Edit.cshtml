@model DatabaseDeneme.Models.Kisi

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4>Kullanıcı Düzenle</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label class="form-label">İsim</label>
                            <input asp-for="Name" class="table-hover form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Yaş</label>
                            <input asp-for="Age" class="form-control" type="number" />
                        </div>

                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-success">Değişiklikleri Kaydet</button>
                            <a asp-action="Index" class="btn btn-secondary">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>