@model IEnumerable<DatabaseDeneme.Models.Kisi>

<div class="container mt-5">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="card-title m-0">Kullanıcı Yönetim Paneli</h3>
        </div>
        <div class="card-body">
            <table class="table table-hover table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Sıra No</th>
                        <th>Kullanıcı Adı</th>
                        <th>Yaş</th>
                        <th class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int sira = 1;
                    }
                    
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td><strong>@sira</strong></td>
                            <td>@user.Name</td>
                            <td>
                                @if (user.Age < 18)
                                {
                                    <span class="badge bg-warning text-dark">Genç (@user.Age)</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">Yetişkin (@user.Age)</span>
                                }
                            </td>
                            <td class="text-center">
                                <a href="/Home/Edit/@user.Id" class="btn btn-sm btn-outline-primary">Düzenle</a>
                                
                                <a href="/Home/Delete/@user.Id"
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('@user.Name adlı kaydı silmek istediğinize emin misiniz?');">
                                    Sil
                                </a>
                            </td>
                        </tr>
                        sira++;
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>